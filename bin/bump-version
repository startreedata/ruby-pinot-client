#!/usr/bin/env bash
# Usage:
#   bin/bump-version 1.4.0          # set exact version
#   bin/bump-version --major        # bump major (1.2.3 -> 2.0.0)
#   bin/bump-version --minor        # bump minor (1.2.3 -> 1.3.0)
#   bin/bump-version --patch        # bump patch (1.2.3 -> 1.2.4)
set -euo pipefail

VERSION_FILE="lib/pinot/version.rb"

current() {
  grep -oE '[0-9]+\.[0-9]+\.[0-9]+' "$VERSION_FILE"
}

write_version() {
  local v="$1"
  sed -i.bak "s/VERSION = \".*\"/VERSION = \"$v\"/" "$VERSION_FILE"
  rm -f "${VERSION_FILE}.bak"
  echo "Bumped to $v"
}

if [ $# -eq 0 ]; then
  echo "Current version: $(current)"
  echo "Usage: $0 <version>|--major|--minor|--patch"
  exit 0
fi

CURRENT=$(current)
MAJOR=$(echo "$CURRENT" | cut -d. -f1)
MINOR=$(echo "$CURRENT" | cut -d. -f2)
PATCH=$(echo "$CURRENT" | cut -d. -f3)

case "$1" in
  --major) write_version "$((MAJOR + 1)).0.0" ;;
  --minor) write_version "${MAJOR}.$((MINOR + 1)).0" ;;
  --patch) write_version "${MAJOR}.${MINOR}.$((PATCH + 1))" ;;
  [0-9]*) write_version "$1" ;;
  *)
    echo "Error: unknown argument '$1'"
    echo "Usage: $0 <version>|--major|--minor|--patch"
    exit 1
    ;;
esac
